<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <packageSources>
        <clear/>
        <add key="nuget.org" value="https://api.nuget.org/v3/index.json"/>
        <add key="github" value="https://nuget.pkg.github.com/renzojared/index.json"/>
    </packageSources>
    <packageSourceMapping>
        <!-- DotEmilu* is mapped to both feeds intentionally:
             prerelease versions are published to GitHub Packages,
             stable versions are published to NuGet.org. -->
        <packageSource key="nuget.org">
            <package pattern="*"/>
        </packageSource>
        <packageSource key="github">
            <package pattern="DotEmilu"/>
            <package pattern="DotEmilu.*"/>
        </packageSource>
    </packageSourceMapping>
</configuration>
